{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "PointMax master sync: ExtractedSource schema. Used as Gemini responseSchema and as in-repo contract documentation. Keep flat (no $ref) for Gemini compatibility.",
  "title": "ExtractedSource",
  "description": "One file per registry source. Output of a single Gemini scrape run for sources/extracted/<sourceId>.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceId",
    "sourceUrl",
    "fetchedAt",
    "promptVersion",
    "extractor",
    "geminiModel"
  ],
  "properties": {
    "sourceId": {
      "type": "string",
      "description": "Matches the id in sources/registry.yaml."
    },
    "sourceUrl": {
      "type": "string",
      "format": "uri"
    },
    "fetchedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of when this extraction completed."
    },
    "promptVersion": {
      "type": "string",
      "description": "e.g. \"card-v1.0\" - referencing the extractor prompt file used."
    },
    "extractor": {
      "type": "string",
      "enum": ["card", "jal-tokuyaku", "point-partner", "payment-app", "campaign", "jcb-jpoint", "ongoing-program"]
    },
    "geminiModel": {
      "type": "string",
      "description": "e.g. \"gemini-2.5-pro\""
    },
    "notes": {
      "type": "string",
      "description": "Free-form comments from Gemini about the extraction (warnings, caveats, etc.)."
    },

    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cardId", "evidenceQuote", "explicitness", "ambiguity"],
        "properties": {
          "cardId": { "type": "string", "description": "Must match an existing Card.id in seed.ts." },
          "name": { "type": "string" },
          "grade": { "type": "string" },
          "defaultRate": { "type": "number", "minimum": 0, "maximum": 1, "description": "0.01 = 1%." },
          "defaultCurrencyId": { "type": "string" },
          "evidenceQuote": { "type": "string", "minLength": 1 },
          "evidenceUrl": { "type": "string", "format": "uri" },
          "explicitness": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },

    "storeRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cardId",
          "storeId",
          "rate",
          "currencyId",
          "evidenceQuote",
          "explicitness",
          "ambiguity"
        ],
        "properties": {
          "cardId": { "type": "string" },
          "storeId": { "type": "string", "description": "Must match an existing Store.id, or be added via stores[] in the same extraction." },
          "paymentAppId": { "type": "string", "description": "Only set if this rule applies only to a specific PaymentApp." },
          "rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "currencyId": { "type": "string" },
          "monthlyCapAmountYen": { "type": "integer", "minimum": 0 },
          "notes": { "type": "string" },
          "validFrom": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD). 公式ページに明示された開始日のみ。"
          },
          "validTo": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD). 公式ページに明示された終了日のみ。"
          },
          "evidenceQuote": { "type": "string", "minLength": 1 },
          "evidenceUrl": { "type": "string", "format": "uri" },
          "explicitness": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },

    "categoryRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cardId",
          "category",
          "rate",
          "currencyId",
          "evidenceQuote",
          "explicitness",
          "ambiguity"
        ],
        "properties": {
          "cardId": { "type": "string" },
          "category": { "type": "string", "description": "e.g. \"JAL特約店\", \"コンビニ\"." },
          "paymentAppId": { "type": "string" },
          "rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "currencyId": { "type": "string" },
          "monthlyCapAmountYen": { "type": "integer", "minimum": 0 },
          "notes": { "type": "string" },
          "validFrom": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD). 公式ページに明示された開始日のみ。"
          },
          "validTo": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD). 公式ページに明示された終了日のみ。"
          },
          "evidenceQuote": { "type": "string", "minLength": 1 },
          "evidenceUrl": { "type": "string", "format": "uri" },
          "explicitness": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },

    "stores": {
      "type": "array",
      "description": "New stores not yet in seed.ts. The storeId is proposed; collision triggers a needsReview Issue.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "storeId",
          "name",
          "evidenceQuote",
          "explicitness",
          "ambiguity"
        ],
        "properties": {
          "storeId": { "type": "string", "description": "Proposed slug. lowercase kebab-case." },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "evidenceQuote": { "type": "string", "minLength": 1 },
          "evidenceUrl": { "type": "string", "format": "uri" },
          "explicitness": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },

    "loyaltyRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pointCardId",
          "storeId",
          "rate",
          "evidenceQuote",
          "explicitness",
          "ambiguity"
        ],
        "properties": {
          "pointCardId": { "type": "string" },
          "storeId": { "type": "string" },
          "rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "currencyId": { "type": "string", "description": "Usually omit; defaults to PointCard.currencyId." },
          "notes": { "type": "string" },
          "validFrom": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD). 公式ページに明示された開始日のみ。"
          },
          "validTo": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD). 公式ページに明示された終了日のみ。"
          },
          "evidenceQuote": { "type": "string", "minLength": 1 },
          "evidenceUrl": { "type": "string", "format": "uri" },
          "explicitness": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },

    "paymentApps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "paymentAppId",
          "evidenceQuote",
          "explicitness",
          "ambiguity"
        ],
        "properties": {
          "paymentAppId": { "type": "string" },
          "name": { "type": "string" },
          "defaultBonusRate": { "type": "number", "minimum": 0, "maximum": 1 },
          "defaultBonusCurrencyId": { "type": "string" },
          "chargeBased": { "type": "boolean" },
          "compatibleCardIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cardSpecificBonusRates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["cardId", "rate"],
              "properties": {
                "cardId": { "type": "string" },
                "rate": { "type": "number", "minimum": 0, "maximum": 1 },
                "currencyId": { "type": "string" },
                "notes": { "type": "string" },
                "validFrom": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                  "description": "ISO date (YYYY-MM-DD). 公式ページに明示された開始日のみ。"
                },
                "validTo": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                  "description": "ISO date (YYYY-MM-DD). 公式ページに明示された終了日のみ。"
                }
              }
            }
          },
          "evidenceQuote": { "type": "string", "minLength": 1 },
          "evidenceUrl": { "type": "string", "format": "uri" },
          "explicitness": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },

    "programs": {
      "type": "array",
      "description": "New BenefitProgram proposals (v3+ canonical model). Used by the campaign extractor for period-limited promotions (validFrom/validTo) and any program-shaped benefit.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "programId",
          "rate",
          "currencyId",
          "evidenceQuote",
          "explicitness",
          "ambiguity"
        ],
        "properties": {
          "programId": { "type": "string", "description": "Proposed BenefitProgram.id (kebab-case slug, e.g. prog-jre-campaign-...)." },
          "name": { "type": "string" },
          "cardIds": { "type": "array", "items": { "type": "string" }, "description": "クレカ保有要件 (OR)。" },
          "pointCardId": { "type": "string", "description": "提示するポイントカード (loyalty 系)。" },
          "paymentAppId": { "type": "string", "description": "特定 paymentApp 経由限定。" },
          "rate": { "type": "number", "minimum": 0, "maximum": 1, "description": "0.01 = 1%." },
          "currencyId": { "type": "string" },
          "bonusType": { "type": "string", "enum": ["primary", "addOn"] },
          "validFrom": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD). 公式ページに明示された開始日のみ。"
          },
          "validTo": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD). 公式ページに明示された終了日のみ。"
          },
          "recurringDays": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1, "maximum": 31 },
            "description": "毎月の日にち限定 (1=1日 .. 31=31日)。domain の ruleActiveAt (now.getDate()) と同義で、曜日ではない。例: 5のつく日 → [5,15,25]。明示時のみ。"
          },
          "recurringWeekdays": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0, "maximum": 6 },
            "description": "曜日限定 (0=日曜 .. 6=土曜)。例: 毎週日曜 → [0]。日にち限定 (recurringDays) とは別フィールド。明示時のみ。"
          },
          "description": { "type": "string" },
          "officialUrl": { "type": "string", "format": "uri" },
          "entryUrl": { "type": "string", "format": "uri", "description": "エントリー / 参加サイト URL。officialUrl が制度解説ページ、entryUrl はユーザーが踏む先 (例: キャンペーン参加ページ、提携店検索トップ)。" },
          "conditions": { "type": "string" },
          "monthlyCapAmountYen": { "type": "integer", "minimum": 0 },
          "notes": { "type": "string" },
          "evidenceQuote": { "type": "string", "minLength": 1 },
          "evidenceUrl": { "type": "string", "format": "uri" },
          "explicitness": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },

    "memberships": {
      "type": "array",
      "description": "StoreProgramMembership proposals: M2M join of a BenefitProgram (programId) to a Store (storeId).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "programId",
          "storeId",
          "evidenceQuote",
          "explicitness",
          "ambiguity"
        ],
        "properties": {
          "programId": { "type": "string", "description": "対象 BenefitProgram.id (既存 or 同抽出の programs[] で追加)。" },
          "storeId": { "type": "string", "description": "既存 Store.id、または同抽出の stores[] で追加。" },
          "overrideRate": { "type": "number", "minimum": 0, "maximum": 1 },
          "overrideCurrencyId": { "type": "string" },
          "notes": { "type": "string" },
          "evidenceQuote": { "type": "string", "minLength": 1 },
          "evidenceUrl": { "type": "string", "format": "uri" },
          "explicitness": { "type": "number", "minimum": 0, "maximum": 1 },
          "ambiguity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
